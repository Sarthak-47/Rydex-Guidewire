'use client'
import { useState, useEffect, useRef } from 'react'
import Link from 'next/link'
import { claimsApi, demoApi, Claim } from '@/lib/api'
import ClaimModal from '@/components/ClaimModal'

interface AdminClaim {
  id: string
  worker_id: string
  worker_name?: string
  status: string
  as_score: number
  payout_amount_rs: number
  created_at: string
}

const ZONES = [
  { id: 'zone-bandra',  label: 'Bandra West', risk: 0.82, factor: 1.35, pin: '400051' },
  { id: 'zone-dharavi', label: 'Dharavi–Sion', risk: 0.74, factor: 1.25, pin: '400017' },
  { id: 'zone-powai',   label: 'Powai', risk: 0.28, factor: 0.92, pin: '400092' },
  { id: 'zone-andheri', label: 'Andheri West', risk: 0.55, factor: 1.10, pin: '400058' },
  { id: 'zone-dadar',   label: 'Dadar', risk: 0.48, factor: 1.08, pin: '400016' },
]

const TRIGGERS = [
  { value: 'rainfall', label: 'Rainfall >50mm' },
  { value: 'aqi',      label: 'AQI >300'       },
  { value: 'heat',     label: 'Heat >40°C'     },
  { value: 'traffic',  label: 'Traffic <8km/h' },
  { value: 'flood',    label: 'Micro-flood'    },
]

export default function AdminPage() {
  const [claims, setClaims] = useState<Claim[]>([])
  const [loading, setLoading] = useState(true)
  const [triggerZone, setTriggerZone] = useState('zone-bandra')
  const [triggerType, setTriggerType] = useState('rainfall')
  const [triggerLoading, setTriggerLoading] = useState(false)
  const [triggerStatus, setTriggerStatus] = useState<'idle' | 'syncing' | 'ml' | 'approved' | 'payout'>('idle')
  const [selectedClaim, setSelectedClaim] = useState<Claim | null>(null)
  const prevIdsRef = useRef<Set<string>>(new Set())
  const [highlightIds, setHighlightIds] = useState<Set<string>>(new Set())

  useEffect(() => {
    let mounted = true
    const fetch = async () => {
      const r = await claimsApi.adminAll()
      if (!mounted) return
      const next = r.data as any[]
      const nextIds = new Set(next.map((c) => c.id))
      const prev = prevIdsRef.current
      const newlyArrived = next.filter((c) => !prev.has(c.id)).map((c) => c.id)
      prevIdsRef.current = nextIds
      if (newlyArrived.length) {
        const s = new Set<string>(newlyArrived)
        setHighlightIds(s)
        setTimeout(() => setHighlightIds(new Set()), 2000)
      }
      setClaims(r.data)
      setLoading(false)
    }
    fetch()
    const t = setInterval(fetch, 5000)
    return () => {
      mounted = false
      clearInterval(t)
    }
  }, [])

  async function handleFire() {
    setTriggerLoading(true)
    setTriggerStatus('syncing')
    
    try {
      await demoApi.fireTrigger(triggerZone, triggerType)
      
      // Multi-step visual pipeline for the demo
      setTimeout(() => setTriggerStatus('ml'), 1000)
      setTimeout(() => setTriggerStatus('approved'), 2500)
      setTimeout(() => setTriggerStatus('payout'), 4000)
      
      // Multiple refreshes to catch the DB commits
      setTimeout(() => claimsApi.adminAll().then(r => setClaims(r.data)), 2000)
      setTimeout(() => claimsApi.adminAll().then(r => setClaims(r.data)), 5000)
      
      setTimeout(() => {
        setTriggerStatus('idle')
        setTriggerLoading(false)
      }, 6000)
      
    } catch {
      setTriggerStatus('idle')
      setTriggerLoading(false)
      alert('Error firing oracle trigger')
    }
  }

  async function handleFraudDemo() {
    setTriggerLoading(true)
    setTriggerStatus('syncing')
    try {
      await demoApi.fireFraudCase(triggerZone)
      setTimeout(() => setTriggerStatus('ml'), 800)
      setTimeout(() => setTriggerStatus('approved'), 1800)
      setTimeout(() => setTriggerStatus('payout'), 3000)
      setTimeout(() => setTriggerStatus('idle'), 4500)
    } catch {
      setTriggerStatus('idle')
      alert('Error firing fraud demo')
    } finally {
      setTriggerLoading(false)
    }
  }

  const totalPaid = claims.reduce((a, c) => a + c.payout_amount_rs, 0)
  const autoApproved = claims.filter((c) => c.status === 'auto_approved').length
  const autoApprovedPct = claims.length ? Math.round((autoApproved / claims.length) * 100) : 0
  const avgAs = claims.length
    ? Math.round(claims.reduce((a, c) => a + c.as_score, 0) / claims.length)
    : 0

  const asBuckets = [
    { label: '0-44', count: claims.filter((c) => c.as_score < 45).length },
    { label: '45-74', count: claims.filter((c) => c.as_score >= 45 && c.as_score < 75).length },
    { label: '75-100', count: claims.filter((c) => c.as_score >= 75).length },
  ]
  const maxBucket = Math.max(...asBuckets.map((b) => b.count), 1)

  if (loading) {
    return (
      <div className="min-h-screen flex items-center justify-center bg-background">
         <span className="material-symbols-outlined animate-spin text-4xl text-primary font-bold" data-icon="sync">sync</span>
      </div>
    )
  }

  return (
<div className="bg-background text-on-background font-body min-h-screen selection:bg-primary/20">
    <header className="sticky top-0 z-40 bg-surface/80 backdrop-blur-md border-b border-surface-container h-16 flex items-center justify-between px-5">
        <div className="flex items-center gap-3">
            <span className="material-symbols-outlined text-[#1D9E75] dark:text-[#26C491] text-2xl" data-icon="shield">shield</span>
            <div className="h-4 w-px bg-surface-container-highest mx-1"></div>
            <h1 className="text-xs font-headline font-bold uppercase tracking-tight text-on-surface-variant">Console</h1>
        </div>
        <div className="flex items-center gap-3">
             <Link href="/login" className="text-xs text-primary font-bold">Worker View →</Link>
        </div>
    </header>

    <main className="pb-32 pt-4 px-5 max-w-lg mx-auto space-y-6">
        {/* Welcome & Status */}
        <section className="flex items-center justify-between">
            <div>
                <h2 className="text-lg font-headline font-extrabold text-on-background">Network Overview</h2>
                <div className="flex items-center gap-1.5 mt-0.5">
                    <span className="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                    <span className="text-[10px] font-mono font-medium text-outline uppercase">Oracle Live Feed</span>
                </div>
            </div>
        </section>

        {/* Demo Trigger Form */}
        <section className="bg-surface-container-lowest p-4 rounded-2xl border border-surface-variant/30 space-y-3">
            <h4 className="font-headline font-bold text-sm text-primary uppercase tracking-widest">Oracle Test Bench</h4>
            <div className="flex gap-2">
                <select value={triggerZone} onChange={(e) => setTriggerZone(e.target.value)} className="flex-1 text-xs border border-surface-container-high rounded-xl px-2 py-2 bg-surface focus:outline-none font-bold text-on-surface">
                   {ZONES.map((z) => (<option key={z.id} value={z.id}>{z.label}</option>))}
                </select>
                <select value={triggerType} onChange={(e) => setTriggerType(e.target.value)} className="flex-1 text-xs border border-surface-container-high rounded-xl px-2 py-2 bg-surface focus:outline-none font-bold text-on-surface">
                   {TRIGGERS.map((t) => (<option key={t.value} value={t.value}>{t.label}</option>))}
                </select>
            </div>
            <div className="border border-surface-variant/40 rounded-xl p-4 bg-surface-container mt-4">
              <h4 className="font-headline font-bold text-sm text-[#DC2626] uppercase tracking-widest mb-3 flex items-center gap-2">
                <span className="material-symbols-outlined">warning</span>
                Live Fraud Detection Demo
              </h4>
              <div className="grid grid-cols-2 gap-3 mb-4">
                <div className="border-l-4 border-l-[#1D9E75] bg-surface rounded-r-xl p-3 border-y border-r border-[#1D9E75]/20 shadow-sm relative overflow-hidden">
                  <div className="absolute top-0 right-0 p-1 opacity-10">
                    <span className="material-symbols-outlined text-4xl">verified_user</span>
                  </div>
                  <h5 className="font-headline font-bold text-[11px] uppercase tracking-wider text-[#1D9E75] mb-0.5">Legitimate Claim</h5>
                  <p className="text-[10px] font-bold text-on-surface mb-2">Salim Khan</p>
                  <div className="flex justify-between items-center mb-1">
                    <span className="text-[10px] font-bold">AS Score: 79 <span className="text-[#1D9E75]">●</span></span>
                  </div>
                  <div className="flex gap-1 mb-3 bg-surface-container p-1 rounded">
                    <div className="h-1.5 flex-1 bg-[#1D9E75] rounded-full"></div>
                    <div className="h-1.5 flex-1 bg-[#1D9E75] rounded-full"></div>
                    <div className="h-1.5 flex-1 bg-[#1D9E75] rounded-full"></div>
                    <div className="h-1.5 flex-1 bg-[#1D9E75] rounded-full"></div>
                    <div className="h-1.5 flex-1 bg-[#1D9E75] rounded-full"></div>
                  </div>
                  <div className="flex items-center gap-1 text-[#1D9E75] text-[9px] font-bold uppercase mb-1 bg-[#1D9E75]/10 w-max px-1.5 py-0.5 rounded">
                    <span className="material-symbols-outlined text-[12px]">check_circle</span>
                    Auto Approved
                  </div>
                  <p className="text-[10px] font-mono font-bold">₹340 paid out</p>
                </div>
                
                <div className="border-l-4 border-l-[#DC2626] bg-surface rounded-r-xl p-3 border-y border-r border-[#DC2626]/20 shadow-sm relative overflow-hidden">
                  <div className="absolute top-0 right-0 p-1 opacity-10">
                    <span className="material-symbols-outlined text-4xl">gpp_bad</span>
                  </div>
                  <h5 className="font-headline font-bold text-[11px] uppercase tracking-wider text-[#DC2626] mb-0.5">Fraud Attempt</h5>
                  <p className="text-[10px] font-bold text-on-surface mb-2">Salim Khan</p>
                  <div className="flex justify-between items-center mb-1">
                    <span className="text-[10px] font-bold">AS Score: 11 <span className="text-[#DC2626]">●</span></span>
                  </div>
                  <div className="flex gap-1 mb-3 bg-surface-container p-1 rounded">
                    <div className="h-1.5 flex-1 bg-[#DC2626] rounded-full"></div>
                    <div className="h-1.5 flex-1 bg-[#DC2626] rounded-full"></div>
                    <div className="h-1.5 flex-1 bg-[#DC2626] rounded-full"></div>
                    <div className="h-1.5 flex-1 bg-[#DC2626] rounded-full"></div>
                    <div className="h-1.5 flex-1 bg-[#DC2626] rounded-full"></div>
                  </div>
                  <div className="flex items-center gap-1 text-[#DC2626] text-[9px] font-bold uppercase mb-1 bg-[#DC2626]/10 w-max px-1.5 py-0.5 rounded">
                    <span className="material-symbols-outlined text-[12px]">cancel</span>
                    Manual Review
                  </div>
                  <p className="text-[10px] font-mono font-bold">₹0 — payout held</p>
                </div>
              </div>
              
              <div className="flex gap-2">
                <button onClick={handleFire} disabled={triggerLoading} className="flex-1 bg-[#1D9E75] hover:bg-[#1D9E75]/90 py-2.5 rounded-xl text-white font-bold uppercase tracking-widest text-[9px] transition-transform active:scale-95 shadow-sm flex justify-center items-center h-10">
                  {triggerLoading && triggerStatus !== 'idle' ? <span className="material-symbols-outlined text-[14px] animate-spin">sync</span> : 'Fire Legitimate Claim'}
                </button>
                <button onClick={handleFraudDemo} disabled={triggerLoading} className="flex-1 bg-[#DC2626] hover:bg-[#DC2626]/90 py-2.5 rounded-xl text-white font-bold uppercase tracking-widest text-[9px] transition-transform active:scale-95 shadow-sm flex justify-center items-center h-10">
                  {triggerLoading && triggerStatus !== 'idle' ? <span className="material-symbols-outlined text-[14px] animate-spin">sync</span> : 'Fire Fraud Case'}
                </button>
              </div>
              <p className="text-[9px] text-outline mt-3 text-center pt-2 border-t border-surface-variant/40">
                The Isolation Forest model flagged an anomaly — GPS spoofing detected, earnings inflated 210% above baseline, no platform dispatch activity.
              </p>
            </div>
        </section>

        {/* Stats Row */}
        <div className="grid grid-cols-2 gap-3">
            <div className="bg-surface-container-lowest p-4 rounded-2xl border border-surface-variant/30">
                <p className="text-[10px] font-label uppercase tracking-widest text-outline mb-1">Total Claims</p>
                <h3 className="text-xl font-headline font-extrabold text-on-background">{claims.length}</h3>
            </div>
            <div className="bg-surface-container-lowest p-4 rounded-2xl border border-surface-variant/30">
                <p className="text-[10px] font-label uppercase tracking-widest text-outline mb-1">Approved %</p>
                <h3 className="text-xl font-headline font-extrabold text-on-background">{autoApprovedPct}%</h3>
                <div className="w-full h-1 bg-surface-container-high rounded-full mt-3 overflow-hidden">
                    <div className="h-full bg-primary" style={{ width: `${autoApprovedPct}%` }}></div>
                </div>
            </div>
            <div className="bg-surface-container-lowest p-4 rounded-2xl border border-surface-variant/30">
                <p className="text-[10px] font-label uppercase tracking-widest text-outline mb-1">Paid Out</p>
                <h3 className="text-xl font-mono font-extrabold text-on-background">₹{totalPaid.toLocaleString()}</h3>
            </div>
            <div className="bg-surface-container-lowest p-4 rounded-2xl border border-surface-variant/30">
                <p className="text-[10px] font-label uppercase tracking-widest text-outline mb-1">Avg AS</p>
                <h3 className="text-xl font-headline font-extrabold text-on-background">{avgAs}</h3>
                <span className="inline-block mt-2 px-1.5 py-0.5 bg-primary/10 text-primary text-[9px] font-bold rounded">TIER {avgAs >= 75 ? '1' : avgAs >= 45 ? '2' : '3'}</span>
            </div>
        </div>

        {/* AS Score Distribution */}
        <section className="bg-surface-container-lowest p-5 rounded-2xl border border-surface-variant/30">
            <div className="flex justify-between items-start mb-6">
                <div>
                    <h4 className="font-headline font-bold text-base">AS Score Distribution</h4>
                    <p className="text-[11px] text-outline">Network-wide metrics</p>
                </div>
                <span className="text-[10px] font-mono font-bold text-primary bg-primary/5 px-2 py-0.5 rounded">N={claims.length}</span>
            </div>
            <div className="flex items-end gap-3 h-40 border-b border-surface-variant pb-2 px-2">
                <div className="flex-1 flex flex-col justify-end items-center h-full">
                    <div className="w-full bg-[#ef4444]/20 rounded-t-md transition-all" style={{ height: `${Math.max(12, (asBuckets[0].count / maxBucket) * 100)}%` }}></div>
                    <span className="mt-2 text-[9px] font-mono font-bold text-[#ef4444]">0-44</span>
                </div>
                <div className="flex-1 flex flex-col justify-end items-center h-full">
                    <div className="w-full bg-[#f59e0b] rounded-t-md opacity-80 transition-all" style={{ height: `${Math.max(12, (asBuckets[1].count / maxBucket) * 100)}%` }}></div>
                    <span className="mt-2 text-[9px] font-mono font-bold text-[#d97706]">45-74</span>
                </div>
                <div className="flex-1 flex flex-col justify-end items-center h-full">
                    <div className="w-full bg-primary rounded-t-md transition-all" style={{ height: `${Math.max(12, (asBuckets[2].count / maxBucket) * 100)}%` }}></div>
                    <span className="mt-2 text-[9px] font-mono font-bold text-primary">75-100</span>
                </div>
            </div>
        </section>

        {/* Zone Risk Heatmap */}
        <section className="bg-surface-container-lowest p-5 rounded-2xl border border-surface-variant/30">
            <h4 className="font-headline font-bold text-base mb-4">Zone Risk Heatmap</h4>
            <div className="overflow-x-auto no-scrollbar -mx-5 px-5">
                <table className="w-full text-left min-w-[280px]">
                    <thead>
                        <tr className="text-[10px] font-label uppercase tracking-widest text-outline border-b border-surface-variant">
                            <th className="pb-3 font-semibold">Location</th>
                            <th className="pb-3 font-semibold">Risk Index</th>
                            <th className="pb-3 font-semibold text-right">Factor</th>
                        </tr>
                    </thead>
                    <tbody className="divide-y divide-surface-variant/30">
                        {ZONES.map((z) => (
                            <tr key={z.id}>
                                <td className="py-3.5 text-xs font-headline font-semibold text-on-background">{z.label}</td>
                                <td className="py-3.5">
                                    <div className="w-16 h-1.5 bg-surface-variant rounded-full overflow-hidden">
                                        <div className={`h-full ${z.risk > 0.7 ? 'bg-[#ef4444]' : z.risk > 0.5 ? 'bg-[#f59e0b]' : 'bg-primary'}`} style={{ width: `${z.risk * 100}%` }}></div>
                                    </div>
                                </td>
                                <td className="py-3.5 text-right font-mono text-[11px]">{z.factor}x</td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
        </section>

        {/* Live Claims Feed */}
        <section className="space-y-4">
            <div className="flex justify-between items-center px-1">
                <h4 className="font-headline font-bold text-base">Live Claims</h4>
                <span className="bg-primary/10 text-primary text-[9px] px-2 py-0.5 rounded-full font-bold uppercase tracking-wider">Active</span>
            </div>
            <div className="space-y-3">
                {claims.length === 0 ? (
                    <p className="text-center text-[11px] text-on-surface-variant/60 font-medium py-4">Waiting for oracle triggers...</p>
                ) : (
                    (claims as any[]).slice(0, 10).map((c: any) => {
                        const scoreColor = c.as_score >= 75 ? 'text-[#1D9E75]' : c.as_score >= 45 ? 'text-[#D97706]' : 'text-[#DC2626]';
                        const scoreBgColor = c.as_score >= 75 ? 'bg-[#1D9E75]/10' : c.as_score >= 45 ? 'bg-[#D97706]/10' : 'bg-[#DC2626]/10';
                        const decisionText = c.status === 'auto_approved' ? 'Auto Approved' : c.status === 'soft_hold' ? 'Soft Hold' : 'Manual Review';

                        return (
                            <div 
                              key={c.id} 
                              onClick={() => setSelectedClaim(c)}
                              className={`p-4 bg-white rounded-2xl shadow-sm border border-surface-container flex items-center gap-4 transition-all hover:border-primary/40 cursor-pointer active:scale-[0.98] ${
                                highlightIds.has(c.id) ? 'ring-2 ring-primary/40 bg-primary/5' : ''
                              }`}
                            >
                                <div className={`w-10 h-10 rounded-full flex items-center justify-center shrink-0 ${scoreBgColor} ${scoreColor}`}>
                                    <span className="material-symbols-outlined">person</span>
                                </div>
                                <div className="flex-1 min-w-0">
                                    <div className="flex justify-between items-start">
                                        <h5 className="text-xs font-headline font-bold truncate">
                                          {c.worker_name ? c.worker_name : `Worker ${(c.worker_id || 'unknown').replace('worker-', '').substring(0, 5)}`}
                                        </h5>
                                        <span className="text-[10px] text-outline font-medium whitespace-nowrap">{new Date(c.created_at).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' })}</span>
                                    </div>
                                    <div className="flex items-center gap-2 mt-1">
                                        <span className={`text-[10px] font-mono font-bold px-1.5 py-0.5 rounded ${scoreColor} ${scoreBgColor}`}>
                                            AS {c.as_score}
                                        </span>
                                        {c.as_score < 45 && (
                                            <span className="text-[8px] font-bold uppercase text-[#DC2626] bg-[#DC2626]/10 px-1 py-0.5 rounded border border-[#DC2626]/20">
                                                Fraud Flag
                                            </span>
                                        )}
                                        <span className={`text-[9px] px-1.5 rounded font-bold uppercase ${c.status === 'auto_approved' ? 'text-[#1D9E75]' : c.status === 'soft_hold' ? 'text-[#D97706]' : 'text-[#DC2626]'}`}>
                                            {decisionText}
                                        </span>
                                    </div>
                                </div>
                                <div className="text-right">
                                    <p className="font-mono font-bold text-sm text-on-background">₹{c.payout_amount_rs}</p>
                                </div>
                            </div>
                        )
                    })
                )}
            </div>
        </section>

        {selectedClaim && (
          <ClaimModal 
            claim={selectedClaim} 
            onClose={() => setSelectedClaim(null)} 
          />
        )}
    </main>
</div>
  )
}
